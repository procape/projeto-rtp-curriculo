{
  "info": {
    "name": "RTP Curriculo API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@email.com\",\n  \"senha\": \"Senha@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@email.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "forgot-password"]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@email.com\",\n  \"token\": \"abc123\",\n  \"senha\": \"NovaSenha@456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "reset-password"]
            }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Criar Usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cpf\": \"12345678901\",\n  \"nome\": \"Nome Completo\",\n  \"email\": \"usuario@email.com\",\n  \"senha\": \"Senha@123\",\n  \"cargo\": \"usuario\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/user",
              "host": ["{{base_url}}"],
              "path": ["user"]
            }
          }
        },
        {
          "name": "Buscar Usuario por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/user/1",
              "host": ["{{base_url}}"],
              "path": ["user", "1"]
            }
          }
        },
        {
          "name": "Atualizar Usuario",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Nome Atualizado\",\n  \"email\": \"novo@email.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/user/1",
              "host": ["{{base_url}}"],
              "path": ["user", "1"]
            }
          }
        },
        {
          "name": "Deletar Usuario",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/user/1",
              "host": ["{{base_url}}"],
              "path": ["user", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Curriculo",
      "item": [
        {
          "name": "Criar Curriculo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome_completo\": \"Nome Completo\",\n  \"email\": \"curriculo@email.com\",\n  \"telefone\": \"81999990000\",\n  \"rua_logradouro\": \"Av. Exemplo, 123\",\n  \"bairro\": \"Centro\",\n  \"cidade\": \"Recife\",\n  \"escolaridade\": \"Superior Completo\",\n  \"experiencia\": \"2 anos\",\n  \"atuacao\": \"Desenvolvimento Web\",\n  \"habilidades\": \"Python, Flask, SQL\",\n  \"observacoes\": \"Disponivel para inicio imediato\",\n  \"user_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/curriculo",
              "host": ["{{base_url}}"],
              "path": ["curriculo"]
            }
          }
        },
        {
          "name": "Listar Todos os Curriculos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/curriculo",
              "host": ["{{base_url}}"],
              "path": ["curriculo"]
            }
          }
        },
        {
          "name": "Buscar Curriculo por User ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/curriculo/1",
              "host": ["{{base_url}}"],
              "path": ["curriculo", "1"]
            }
          }
        },
        {
          "name": "Atualizar Curriculo",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"atuacao\": \"Desenvolvimento Full Stack\",\n  \"habilidades\": \"Python, Flask, SQLAlchemy, JavaScript\",\n  \"observacoes\": \"Portfólio disponível no GitHub\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/curriculo/1",
              "host": ["{{base_url}}"],
              "path": ["curriculo", "1"]
            }
          }
        },
        {
          "name": "Deletar Curriculo",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/curriculo/1",
              "host": ["{{base_url}}"],
              "path": ["curriculo", "1"]
            }
          }
        }
      ]
    }
  ]
}
